# Environment variables for supost
# Copy to .env and fill in values. Never commit .env to git.
# These are the SAME env vars your Next.js frontend will use.

# Supabase / Postgres (leave empty to use in-memory prototype)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase keys
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App
PORT=8080
VERBOSE=false
FORMAT=json
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Mailgun
MAILGUN_API_KEY=api-key-goes-here
MAILGUN_DOMAIN=mg.supost.com
MAILGUN_FROM_EMAIL=response@mg.supost.com
